{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate:api": "ng-openapi -c openapi.config.ts && prettier --write src/app/infrastructure/api/generated"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/animations": "21.2.13",
    "@angular/cdk": "21.2.6",
    "@angular/common": "21.2.13",
    "@angular/compiler": "21.2.17",
    "@angular/core": "21.2.13",
    "@angular/forms": "21.2.13",
    "@angular/material": "21.2.6",
    "@angular/platform-browser": "21.2.13",
    "@angular/router": "21.2.13",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.11",
    "@angular/cli": "21.2.11",
    "@angular/compiler-cli": "21.2.13",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "21.4.0",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "ng-openapi": "^0.2.21",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.61.1",
    "vitest": "^4.1.9"
  }
}
