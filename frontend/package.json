{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate:api": "ng-openapi -c openapi.config.ts && prettier --write src/app/infrastructure/api/generated"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/router": "^21.2.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "21.3.1",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "ng-openapi": "^0.2.18",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.57.2",
    "vitest": "^4.0.8"
  }
}
